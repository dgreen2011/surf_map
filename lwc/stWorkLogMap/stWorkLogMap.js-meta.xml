<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>St Work Log Map</masterLabel>
    <description>Displays a map for a Production Work Log record using Sitetracker Mapbox resources.</description>

    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>sitetracker__Production_Work_Log__c</object>
            </objects>
        </targetConfig>

        <targetConfig targets="lightning__AppPage">
            <property
                name="workLogId"
                type="String"
                label="Work Log Id"
                description="Optional Work Log record Id to render when used outside a record page."
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
